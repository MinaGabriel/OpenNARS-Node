{
    "version": "0.2.0",
    "configurations": [
        {
            "type": "node",
            "request": "launch",
            "name": "Debug index.ts",
            "skipFiles": ["<node_internals>/**"],
            "program": "${workspaceFolder}/index.ts",
            "runtimeArgs": ["-r", "ts-node/register"],
            "outFiles": ["${workspaceFolder}/**/*.js"],
            "cwd": "${workspaceFolder}",
            "env": {
                "NODE_ENV": "development"
            },
            "console": "integratedTerminal" // Run in the integrated terminal
        },
        {
            "type": "node",
            "request": "launch",
            "name": "Run index.ts (no debug)",
            "program": "${workspaceFolder}/index.ts",
            "runtimeArgs": ["-r", "ts-node/register"],
            "cwd": "${workspaceFolder}",
            "env": {
                "NODE_ENV": "production"
            },
            "noDebug": true,
            "console": "integratedTerminal" // Run in the integrated terminal
        },
        {
            "type": "node",
            "request": "launch",
            "name": "Debug Current File",
            "skipFiles": ["<node_internals>/**"],
            "program": "${file}",
            "runtimeArgs": ["-r", "ts-node/register"],
            "outFiles": ["${workspaceFolder}/**/*.js"],
            "cwd": "${workspaceFolder}",
            "env": {
                "NODE_ENV": "development"
            },
            "console": "integratedTerminal"
        }
    ]
}